# Database connection (same as your Go app)
# Remove ?schema=public as it's not recognized by postgres package
DATABASE_URL="postgresql://garchen_user:your_password@localhost:5432/garchen_archive"

# NextAuth Configuration
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Optional: For production deployment on Vercel
# POSTGRES_URL="your-vercel-postgres-url"
# NEXTAUTH_URL="https://your-domain.vercel.app"

# Content Processing Pipeline API
# Local: http://localhost:8080
# Staging: https://garchen-archive-cp-staging-x2bn6.ondigitalocean.app
PIPELINE_API_URL="http://localhost:8080"
PIPELINE_API_KEY="your-pipeline-api-key"
